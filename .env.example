# API settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Database
DB_URL=sqlite:///trading_predictor.db

# Data settings
STOCK_INTERVAL=1d
STOCK_PERIOD=1y
CRYPTO_TIMEFRAME=1d
CACHE_TTL_SECONDS=3600

# Binance (crypto data)
BINANCE_API_KEY=
BINANCE_SECRET=

# Alpaca broker (paper trading by default)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER_MODE=true

# Paper trading
PAPER_INITIAL_CAPITAL=10000.0
PAPER_MAX_OPEN_POSITIONS=5
PAPER_COMMISSION_RATE=0.001

# Backtesting
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2026-04-05
BACKTEST_INITIAL_CAPITAL=10000.0
BACKTEST_STOCK_SYMBOLS=AAPL,MSFT,GOOGL,TSLA,AMZN,SPY,QQQ
BACKTEST_CRYPTO_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,XRP/USDT
BACKTEST_TIMEFRAMES=1d

# Live trading risk controls
LIVE_TRADING_ENABLED=false
LIVE_MAX_RISK_PCT=2.0
LIVE_DAILY_LOSS_LIMIT_PCT=5.0
LIVE_MAX_OPEN_POSITIONS=5
LIVE_REQUIRE_MANUAL_APPROVAL=true

# ML model settings
CONFIDENCE_THRESHOLD=0.70
MIN_INDICATOR_ALIGNMENT=3
MODEL_DIR=models

# Auth / Security
SECRET_KEY=change-me-in-production

# Monitoring
MONITORING_ENABLED=true
HEALTH_CHECK_INTERVAL=300

# Alerts
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_TO=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_password

ALERT_SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Live Trading Ready Check
MIN_WIN_RATE=0.55
MIN_PROFIT_FACTOR=1.5
MIN_SHARPE_RATIO=1.0
MAX_DRAWDOWN=0.20
MIN_PAPER_TRADING_DAYS=7
