# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
API_TIMEOUT=30

# Stock data (yfinance)
STOCK_INTERVAL=1d
STOCK_PERIOD=1y

# Crypto data (Binance via CCXT)
BINANCE_API_KEY=
BINANCE_SECRET=
CRYPTO_EXCHANGE=binance
CRYPTO_TIMEFRAME=1d
CRYPTO_LIMIT=365

# Database
DB_URL=sqlite:///trading_predictor.db

# Cache
CACHE_DIR=cache
CACHE_TTL_SECONDS=3600

# Model
MODEL_DIR=models
CONFIDENCE_THRESHOLD=0.70
MIN_INDICATOR_ALIGNMENT=3
TRAIN_TEST_SPLIT=0.8
RANDOM_STATE=42
N_ESTIMATORS=100

# Risk
DEFAULT_RISK_PERCENT=2.0
DEFAULT_REWARD_RATIO=2.0
SL_PERCENT_LONG=2.0
SL_PERCENT_SHORT=2.0
MAX_POSITION_SIZE=0.20
